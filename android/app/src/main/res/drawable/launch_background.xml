<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash screen — white background with the Không Dịch logo
     centered. The logo image is generated from the backend's
     static/icons/og-default.png by scripts/generate_mobile_icons.py. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/white" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/ic_launcher_splash" />
    </item>
</layer-list>
